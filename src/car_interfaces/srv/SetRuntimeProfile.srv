# Request an asynchronous switch between mutually-exclusive runtime profiles.
# A successful response means that the manager accepted and queued the request;
# callers must watch /runtime/status for READY or FAILED.
string profile
string map_path
string route_file
bool use_yolo
# Registered car_vision model name; used only when use_yolo is true.
string yolo_active_model
# Optional registered model names to run concurrently; takes precedence over
# yolo_active_model when non-empty.
string[] yolo_active_models
---
bool accepted
uint32 generation
string state
string message
